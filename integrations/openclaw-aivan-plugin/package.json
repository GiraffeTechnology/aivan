{
  "name": "@giraffetechnology/openclaw-aivan",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin bridge for AIVAN, a local-first AI trade salesperson assistant",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GiraffeTechnology/aivan.git"
  },
  "license": "MIT",
  "author": "Giraffe Technology",
  "keywords": [
    "openclaw",
    "clawhub",
    "trade",
    "sourcing",
    "aivan",
    "ai-agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.6.9",
    "typebox": "^1.3.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": "1.0"
    },
    "build": {
      "openclawVersion": ">=2026.3.22"
    }
  }
}
