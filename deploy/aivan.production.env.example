# AIVAN production environment (CTYUN private-domain, CPU-only).
# Copy to /opt/giraffe/aivan/.env and fill secrets. Do NOT commit the real file.
#
# Model decision:
#   qwen3.5:2b   -> REQUIRED production private-domain local model
#   qwen3.5:4b   -> rejected (CPU-only smoke: 100% failure, ~90s/case)
#   qwen3.5:0.8b -> historical baseline only
# External LLM/VLM APIs are OFF and require explicit approval.

AIVAN_ENV=production
# Fail-closed auth: at least one of these MUST be set in production.
AIVAN_API_KEY=
AIVAN_AUTH_SECRET=
AIVAN_HOST=127.0.0.1
AIVAN_PORT=8765
AIVAN_DB_URL=sqlite:////opt/giraffe/aivan/data/aivan.db
AIVAN_LOG_LEVEL=INFO
AIVAN_REQUIRE_HUMAN_APPROVAL=true

# ── Private-domain local model (production) ──────────────────────────────────
AIVAN_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:2b
AIVAN_LLM_API_ENABLED=true

# ── External model policy: OFF, approval-gated ───────────────────────────────
AIVAN_EXTERNAL_MODEL_API_ENABLED=false
AIVAN_EXTERNAL_MODEL_API_AUTO_ALLOWED=false
AIVAN_VLM_API_ENABLED=false
AIVAN_VLM_PROVIDER=disabled

# ── Supplier boundary: no fabricated suppliers in production ──────────────────
AIVAN_ALLOW_STUB_SUPPLIERS=false

# ── GLTG (lead-time authority) ───────────────────────────────────────────────
GLTG_API_BASE_URL=http://127.0.0.1:8090
GLTG_API_TIMEOUT_SECONDS=30
GLTG_LOCAL_LLM_ENABLED=true
GLTG_LLM_PROVIDER=ollama
GLTG_LLM_MODEL=qwen3.5:2b

# ── Language skill (canonicalization; fail-soft) ─────────────────────────────
AIVAN_LANGUAGE_SKILL_ENABLED=true
AIVAN_LANGUAGE_SKILL_BASE_URL=http://127.0.0.1:8788
AIVAN_LANGUAGE_SKILL_TIMEOUT_SECONDS=10
AIVAN_LANGUAGE_SKILL_FAIL_SOFT=true

# ── OpenClaw (real gateway in production; never mock) ─────────────────────────
OPENCLAW_MOCK_MODE=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=

# ── giraffe-db / GPM ─────────────────────────────────────────────────────────
GIRAFFE_DB_BASE_URL=
GIRAFFE_DB_SERVICE_AUTH_SECRET=
GPM_LLM_RUNTIME_MODE=live
