AIVAN_ENV=local
AIVAN_HOST=127.0.0.1
AIVAN_PORT=8765
AIVAN_DB_URL=sqlite:///./data/aivan.db
AIVAN_LOG_LEVEL=INFO
AIVAN_REQUIRE_HUMAN_APPROVAL=true

OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_SEND_ENDPOINT=/messages/send
OPENCLAW_MOCK_MODE=true
OPENCLAW_MARKETPLACE_ENABLED=true
OPENCLAW_MARKETPLACE_SEARCH_ENDPOINT=/marketplaces/search
OPENCLAW_MARKETPLACE_CONTACT_ENDPOINT=/marketplaces/contact

AIVAN_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GEMINI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=
AIVAN_LLM_TIMEOUT_SECONDS=30
AIVAN_LLM_MAX_RETRIES=2
AIVAN_LLM_TEMPERATURE=0

AIVAN_ALIBABA_MODE=mock
ALIBABA_API_BASE_URL=
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=
ALIBABA_PLATFORM=1688|alibaba_com|auto

AIVAN_WEB_SEARCH_PROVIDER=mock
AIVAN_WEB_SEARCH_MAX_RESULTS=10
AIVAN_WEB_SEARCH_TIMEOUT_SECONDS=20
OPENCLAW_SEARCH_ENABLED=true
OPENCLAW_SEARCH_ENDPOINT=/search/web
SERP_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

AIVAN_ENABLE_UNKNOWN_SUPPLIER_RISK_SEARCH=true
AIVAN_BLOCK_CRITICAL_RISK_SUPPLIERS=false
AIVAN_REQUIRE_RISK_REVIEW_FOR_UNKNOWN_SUPPLIERS=true

AIVAN_DEFAULT_MARGIN_RATE=0.15
AIVAN_HIDE_SUPPLIER_IDENTITY_FROM_BUYER=true
AIVAN_HIDE_SUPPLIER_PRICE_FROM_BUYER=true
