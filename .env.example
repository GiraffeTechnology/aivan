AIVEN_ENV=local
AIVEN_HOST=127.0.0.1
AIVEN_PORT=8765
AIVEN_DB_URL=sqlite:///./data/aiven.db
AIVEN_LOG_LEVEL=INFO
AIVEN_REQUIRE_HUMAN_APPROVAL=true

OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_SEND_ENDPOINT=/messages/send
OPENCLAW_MOCK_MODE=true
OPENCLAW_MARKETPLACE_ENABLED=true
OPENCLAW_MARKETPLACE_SEARCH_ENDPOINT=/marketplaces/search
OPENCLAW_MARKETPLACE_CONTACT_ENDPOINT=/marketplaces/contact

AIVEN_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GEMINI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=
AIVEN_LLM_TIMEOUT_SECONDS=30
AIVEN_LLM_MAX_RETRIES=2
AIVEN_LLM_TEMPERATURE=0

AIVEN_ALIBABA_MODE=mock
ALIBABA_API_BASE_URL=
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=
ALIBABA_PLATFORM=1688|alibaba_com|auto

AIVEN_WEB_SEARCH_PROVIDER=mock
AIVEN_WEB_SEARCH_MAX_RESULTS=10
AIVEN_WEB_SEARCH_TIMEOUT_SECONDS=20
OPENCLAW_SEARCH_ENABLED=true
OPENCLAW_SEARCH_ENDPOINT=/search/web
SERP_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

AIVEN_ENABLE_UNKNOWN_SUPPLIER_RISK_SEARCH=true
AIVEN_BLOCK_CRITICAL_RISK_SUPPLIERS=false
AIVEN_REQUIRE_RISK_REVIEW_FOR_UNKNOWN_SUPPLIERS=true

AIVEN_DEFAULT_MARGIN_RATE=0.15
AIVEN_HIDE_SUPPLIER_IDENTITY_FROM_BUYER=true
AIVEN_HIDE_SUPPLIER_PRICE_FROM_BUYER=true
