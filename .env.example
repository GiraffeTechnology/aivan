# Production must set AIVAN_API_KEY or AIVAN_AUTH_SECRET (auth fails closed).
# Local mode may run unauthenticated.
AIVAN_ENV=local
AIVAN_API_KEY=
AIVAN_HOST=127.0.0.1
AIVAN_PORT=8765
AIVAN_DB_URL=sqlite:///./data/aivan.db
AIVAN_LOG_LEVEL=INFO
AIVAN_REQUIRE_HUMAN_APPROVAL=true

OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_SEND_ENDPOINT=/messages/send
OPENCLAW_MOCK_MODE=true
OPENCLAW_MARKETPLACE_ENABLED=true
OPENCLAW_MARKETPLACE_SEARCH_ENDPOINT=/marketplaces/search
OPENCLAW_MARKETPLACE_CONTACT_ENDPOINT=/marketplaces/contact

# ── Private-domain model policy ──────────────────────────────────────────────
# The private-domain RFQ baseline must close without any EXTERNAL provider API.
# External provider APIs (OpenAI/Anthropic/Gemini/DashScope/Qwen cloud) are a
# controlled escalation requiring an explicit approval packet — never automatic.
# Private-domain LOCAL LLM endpoints (Ollama serving qwen3.5:0.8b) are allowed.
# ENABLED only means the external connector may be built; every external call
# still requires an explicit ExternalModelApproval. AUTO_ALLOWED (default false,
# never true in private-domain baseline) is the only way to skip per-call approval.
AIVAN_EXTERNAL_MODEL_API_ENABLED=false
AIVAN_EXTERNAL_MODEL_API_AUTO_ALLOWED=false
AIVAN_LLM_API_ENABLED=true
AIVAN_VLM_API_ENABLED=false
AIVAN_VLM_PROVIDER=disabled
# Stub/demo suppliers must never be used in production; enable only for demos.
AIVAN_ALLOW_STUB_SUPPLIERS=false
# GLTG may use a private-domain local LLM (traced, bounded); never external.
GLTG_LOCAL_LLM_ENABLED=false
GLTG_LLM_PROVIDER=ollama
GLTG_LLM_MODEL=qwen3.5:0.8b

AIVAN_LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:0.8b
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GEMINI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=
AIVAN_LLM_TIMEOUT_SECONDS=30
AIVAN_LLM_MAX_RETRIES=2
AIVAN_LLM_TEMPERATURE=0

AIVAN_ALIBABA_MODE=mock
ALIBABA_API_BASE_URL=
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=
ALIBABA_PLATFORM=1688|alibaba_com|auto

AIVAN_WEB_SEARCH_PROVIDER=mock
AIVAN_WEB_SEARCH_MAX_RESULTS=10
AIVAN_WEB_SEARCH_TIMEOUT_SECONDS=20
OPENCLAW_SEARCH_ENABLED=true
OPENCLAW_SEARCH_ENDPOINT=/search/web
SERP_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

AIVAN_ENABLE_UNKNOWN_SUPPLIER_RISK_SEARCH=true
AIVAN_BLOCK_CRITICAL_RISK_SUPPLIERS=false
AIVAN_REQUIRE_RISK_REVIEW_FOR_UNKNOWN_SUPPLIERS=true

AIVAN_DEFAULT_MARGIN_RATE=0.15
AIVAN_HIDE_SUPPLIER_IDENTITY_FROM_BUYER=true
AIVAN_HIDE_SUPPLIER_PRICE_FROM_BUYER=true

# ── GPM / giraffe-db ─────────────────────────────────────────────────────────
# giraffe-db base URL (empty = in-memory fallback, packets lost on restart)
GIRAFFE_DB_BASE_URL=

# GPM LLM runtime mode: mock | live (uses AIVAN_LLM_PROVIDER when live)
GPM_LLM_RUNTIME_MODE=mock

# ── Auth ─────────────────────────────────────────────────────────────────────
# HMAC secret for generating and verifying Bearer tokens
# Required in production; leave empty for dev mode (reads X-Tenant-ID header)
AIVAN_AUTH_SECRET=

# Shared secret for AIVAN → giraffe-db service-to-service auth (X-Service-Auth header).
# Must match GIRAFFE_DB_SERVICE_AUTH_SECRET on the giraffe-db side. Leave empty for dev mode.
GIRAFFE_DB_SERVICE_AUTH_SECRET=

# Standalone GLTG service
GLTG_API_BASE_URL=http://localhost:8090
GLTG_API_TIMEOUT_SECONDS=30

# ── Giraffe Language Skill Layer ─────────────────────────────────────────────
# Shared multilingual canonicalization + deterministic extraction service.
# Used for RFQ intake canonicalization (normalize -> structure/rfq) so explicit
# business facts are never lost to a small local LLM. Fail-soft by default.
AIVAN_LANGUAGE_SKILL_ENABLED=true
AIVAN_LANGUAGE_SKILL_BASE_URL=http://127.0.0.1:8788
AIVAN_LANGUAGE_SKILL_TIMEOUT_SECONDS=10
AIVAN_LANGUAGE_SKILL_FAIL_SOFT=true
